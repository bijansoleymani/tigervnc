<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The app bundles third-party libraries (FLTK, GnuTLS, ...) that are
	     not signed with our Team ID. Allow the hardened runtime to load
	     them. This entitlement is permitted by Apple's notary service. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
