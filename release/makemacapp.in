#!/bin/sh

set -u
set -e
trap onexit INT
trap onexit TERM
trap onexit EXIT

TMPDIR=

onexit()
{
	if [ ! "$TMPDIR" = "" ]; then
		rm -rf $TMPDIR
	fi
}

usage()
{
	echo "$0"
	exit 1
}

UNIVERSAL=0

PACKAGE_NAME=TigerVNC
VERSION=@VERSION@
BUILD=@BUILD@
SRCDIR=@CMAKE_SOURCE_DIR@
BINDIR=@CMAKE_BINARY_DIR@

if [ -f $PACKAGE_NAME.dmg ]; then
	rm -f $PACKAGE_NAME.dmg
fi

umask 022
TMPDIR=`mktemp -d /tmp/$PACKAGE_NAME-build.XXXXXX`
APPROOT="$TMPDIR/dmg/TigerVNC.app"
mkdir -p "$APPROOT/Contents/MacOS"
mkdir -p "$APPROOT/Contents/Resources"

install -m 755 $BINDIR/vncviewer/vncviewer "$APPROOT/Contents/MacOS/"
install -m 644 $SRCDIR/media/icons/tigervnc.icns "$APPROOT/Contents/Resources/"
install -m 644 $BINDIR/release/Info.plist "$APPROOT/Contents/"

for lang in `cat "$SRCDIR/po/LINGUAS"`; do
	mkdir -p "$APPROOT/Contents/Resources/locale/$lang/LC_MESSAGES"
	install -m 644 $BINDIR/po/$lang.mo \
		"$APPROOT/Contents/Resources/locale/$lang/LC_MESSAGES/tigervnc.mo"
done

install -m 644 $SRCDIR/LICENCE.TXT $TMPDIR/dmg/
install -m 644 $SRCDIR/README.rst $TMPDIR/dmg/

# Code sign the app bundle. The identity is configured at cmake time via
# SIGN_IDENTITY (default "-", i.e. ad-hoc) and may be overridden at build
# time with the CODESIGN_IDENTITY environment variable. The hardened
# runtime is always enabled so the same bundle can later be notarized.
SIGN_IDENTITY="${CODESIGN_IDENTITY:-@SIGN_IDENTITY@}"

if [ "$SIGN_IDENTITY" = "-" ]; then
	echo "Code signing $PACKAGE_NAME.app (ad-hoc)"
	codesign --force --deep --options runtime \
		--sign - "$APPROOT"
else
	echo "Code signing $PACKAGE_NAME.app with identity: $SIGN_IDENTITY"
	codesign --force --deep --options runtime --timestamp \
		--sign "$SIGN_IDENTITY" "$APPROOT"
fi

codesign --verify --strict --verbose=2 "$APPROOT"

hdiutil create -fs HFS+ -volname $PACKAGE_NAME-$VERSION \
	-srcfolder "$TMPDIR/dmg" \
	$TMPDIR/$PACKAGE_NAME-$VERSION.dmg

# Sign the dmg itself too, but only for real (non ad-hoc) identities;
# an ad-hoc signed disk image provides no value.
if [ ! "$SIGN_IDENTITY" = "-" ]; then
	echo "Code signing $PACKAGE_NAME-$VERSION.dmg"
	codesign --force --timestamp \
		--sign "$SIGN_IDENTITY" "$TMPDIR/$PACKAGE_NAME-$VERSION.dmg"
fi

cp $TMPDIR/$PACKAGE_NAME-$VERSION.dmg .

exit
